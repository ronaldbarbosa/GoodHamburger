@page "/orders/{OrderId:int}/items"
@inject OrderItemService OrderItemService

<PageTitle>Itens do Pedido</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Itens do Pedido #@OrderId.ToString("000000")</MudText>

<MudPaper>
    <MudTable T="OrderItemResponse"
              Items="_items"
              Hover="true"
              Striped="true"
              Dense="true"
              Loading="_loading">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Produto</MudTh>
            <MudTh>Categoria</MudTh>
            <MudTh>Quantidade</MudTh>
            <MudTh>Preço Unitário</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>#@context.Id.ToString("000000")</MudTd>
            <MudTd>@context.Product.Name</MudTd>
            <MudTd>@context.Product.Category.Name</MudTd>
            <MudTd>@context.Quantity</MudTd>
            <MudTd>R$ @context.UnitPrice</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>Nenhum item encontrado.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Carregando...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    [Parameter] public int OrderId { get; set; }

    private List<OrderItemResponse> _items = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _items = await OrderItemService.GetByOrderAsync(OrderId);
        _loading = false;
    }
}
