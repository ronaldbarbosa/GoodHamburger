@page "/order-items"
@inject OrderItemService OrderItemService

<PageTitle>Itens do Pedido</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Itens do Pedido</MudText>

<MudPaper>
    <MudTable T="OrderItemResponse"
              ServerData="LoadPageAsync"
              @ref="_table"
              Hover="true"
              Striped="true"
              Dense="true"
              RowsPerPage="10">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Produto</MudTh>
            <MudTh>Categoria</MudTh>
            <MudTh>Quantidade</MudTh>
            <MudTh>Preço Unitário</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>#@context.Id.ToString("000000")</MudTd>
            <MudTd>@context.Product.Name</MudTd>
            <MudTd>@context.Product.Category.Name</MudTd>
            <MudTd>@context.Quantity</MudTd>
            <MudTd>@context.UnitPrice</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>Nenhum item encontrado.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Carregando...</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10, 25, 50 }" RowsPerPageString="Linhas por página:" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private MudTable<OrderItemResponse> _table = null!;

    private async Task<TableData<OrderItemResponse>> LoadPageAsync(TableState state, CancellationToken ct)
    {
        var paged = await OrderItemService.GetPagedAsync(state.Page + 1, state.PageSize);
        return new TableData<OrderItemResponse>
        {
            Items = paged.Items,
            TotalItems = paged.TotalItemCount
        };
    }
}
