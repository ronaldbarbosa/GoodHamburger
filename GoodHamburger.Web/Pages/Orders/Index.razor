@page "/orders"
@inject OrderService OrderService

<PageTitle>Pedidos</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Pedidos</MudText>

<MudPaper>
<MudTable T="OrderResponse" Items="orders" Hover="true" Striped="true" Dense="true">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Data</MudTh>
            <MudTh>Subtotal</MudTh>
            <MudTh>Desconto</MudTh>
            <MudTh>Total</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="width: 150px;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>#@context.Id.ToString("000000")</MudTd>
            <MudTd>@context.CreatedAt.ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd>@context.Subtotal</MudTd>
            <MudTd>@context.Discount</MudTd>
            <MudTd>@context.Total</MudTd>
            <MudTd>
                <MudChip T="string" Color="GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" Title="Editar" Size="Size.Small" />
                <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Info" Title="Alterar Status" Size="Size.Small" OnClick="() => ToggleStatus(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Title="Excluir" Size="Size.Small" OnClick="() => DeleteOrder(context.Id)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>Nenhum pedido encontrado.</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText>Carregando...</MudText>
        </LoadingContent>
    </MudTable>
</MudPaper>

@code {
    private List<OrderResponse> orders = [];

    protected override async Task OnInitializedAsync()
    {
        orders = await OrderService.GetAllAsync();
        orders = orders.Where(o => o.Status != "Pending").ToList();
    }

    private Color GetStatusColor(string status)
    {
        return status.ToLower() switch
        {
            "pendente" => Color.Warning,
            "em preparação" => Color.Info,
            "concluído" => Color.Success,
            "cancelado" => Color.Error,
            _ => Color.Default
        };
    }

    private void ToggleStatus(OrderResponse order)
    {
    }

    private void DeleteOrder(int id)
    {
    }
}