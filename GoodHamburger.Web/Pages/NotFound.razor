@page "/not-found"
@layout MainLayout
@inject NavigationManager Navigation

<PageTitle>Página não encontrada</PageTitle>

<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; text-align: center;">
    <MudText Typo="Typo.h1" Style="font-size: 8rem; font-weight: 700; line-height: 1; opacity: 0.15;">404</MudText>
    <MudText Typo="Typo.h4" Class="mt-2 mb-2">Página não encontrada</MudText>
    <MudText Typo="Typo.body1" Color="Color.Default" Class="mb-6">
        A página que você está procurando não existe ou foi movida.
    </MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Home"
               Size="Size.Large"
               OnClick="@(() => Navigation.NavigateTo("/"))">
        Voltar ao início
    </MudButton>
</div>