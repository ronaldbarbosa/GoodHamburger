@inject CartService CartService
@inject NavigationManager Navigation

@if (CartService.IsInitialized)
{
    <div style="position: relative; display: inline-flex;">
        <MudBadge Content="CartService.ItemCount" Color="Color.Default" Overlap="true" Bordered="true">
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart"
                           Color="@(CartService.ItemCount > 0 ? Color.Warning : Color.Inherit)"
                           OnClick="TogglePopover" />
        </MudBadge>

        <MudPopover Open="@_isOpen"
                    AnchorOrigin="Origin.BottomRight"
                    TransformOrigin="Origin.TopRight"
                    Paper="true"
                    Elevation="4"
                    Class="pa-4"
                    Style="min-width: 280px; max-width: 360px;">
            <MudText Typo="Typo.h6" Class="mb-3">Carrinho</MudText>

            @if (!CartService.Items.Any())
            {
                <MudText Typo="Typo.body2" Color="Color.Default">Seu carrinho está vazio.</MudText>
            }
            else
            {
                @foreach (var item in CartService.Items)
                {
                    <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                        <MudText Typo="Typo.body2">@item.ProductName</MudText>
                        <MudText Typo="Typo.body2">@item.UnitPrice</MudText>
                    </div>
                }
                <MudDivider Class="my-3" />
                <div style="display: flex; justify-content: space-between; margin-bottom: 12px;">
                    <MudText Typo="Typo.subtitle2">Total</MudText>
                    <MudText Typo="Typo.subtitle2">@(CartService.CurrentCart?.Total ?? "R$ 0,00")</MudText>
                </div>
            }

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.ShoppingCart"
                       OnClick="GoToCart">
                Ver carrinho
            </MudButton>
        </MudPopover>
    </div>
}

@if (_isOpen)
{
    <div style="position: fixed; inset: 0; z-index: 1299;" @onclick="ClosePopover"></div>
}

@code {
    private bool _isOpen;

    protected override void OnInitialized()
    {
        CartService.OnCartChanged += StateHasChanged;
    }

    private void TogglePopover() => _isOpen = !_isOpen;
    private void ClosePopover() => _isOpen = false;

    private void GoToCart()
    {
        _isOpen = false;
        Navigation.NavigateTo("/cart");
    }
}
